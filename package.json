{
  "name": "simarukun",
  "version": "1.1.0",
  "description": "SimaRukun - RT/RW Management System (Monorepo)",
  "author": "Priyo Gunawan",
  "private": true,
  "license": "MIT",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run start:dev --workspace=apps/api\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "start": "npm run start --workspace=apps/web",
    "start:api": "npm run start:prod --workspace=apps/api",
    "lint": "npm run lint --workspace=apps/web && npm run lint --workspace=apps/api",
    "test": "npm run test --workspace=apps/api && npm run test --workspace=apps/web",
    "test:api": "npm run test --workspace=apps/api",
    "test:web": "npm run test --workspace=apps/web",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "docker:dev": "docker-compose -f docker/dev/docker-compose.yml up -d",
    "docker:dev:down": "docker-compose -f docker/dev/docker-compose.yml down",
    "docker:prod": "docker-compose -f docker/prod/docker-compose.yml up -d --build",
    "docker:prod:down": "docker-compose -f docker/prod/docker-compose.yml down",
    "db:migrate": "npm run typeorm --workspace=apps/api migration:run",
    "db:seed": "ts-node apps/api/src/seed.ts",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist apps/*/.next"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "rt",
    "rw",
    "management",
    "system",
    "nestjs",
    "nextjs",
    "typescript",
    "docker"
  ]
}
