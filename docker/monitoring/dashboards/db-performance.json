{
  "dashboard": {
    "id": null,
    "uid": "db-performance",
    "title": "Database Performance",
    "tags": ["database", "postgres", "performance"],
    "timezone": "browser",
    "schemaVersion": 30,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "type": "stat",
        "title": "Active Connections",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "legendFormat": "Connections"
          }
        ]
      },
      {
        "type": "stat",
        "title": "Database Size",
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "pg_database_size_bytes",
            "legendFormat": "{{datname}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "fillOpacity": 80,
              "lineWidth": 0,
              "spanNulls": false
            }
          }
        }
      },
      {
        "type": "stat",
        "title": "Query Count",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(pg_stat_activity_count[1m])) by (datname)",
            "legendFormat": "{{datname}}"
          }
        ]
      },
      {
        "type": "stat",
        "title": "Average Query Time",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "rate(pg_query_duration_seconds_sum[5m]) / rate(pg_query_duration_seconds_count[5m])",
            "legendFormat": "Avg Time"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "type": "graph",
        "title": "Database Connections Over Time",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "legendFormat": "Connections"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Database Size Over Time",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "pg_database_size_bytes",
            "legendFormat": "{{datname}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "type": "graph",
        "title": "Query Duration Distribution",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "rate(pg_query_duration_seconds_bucket[5m])",
            "legendFormat": "{{le}}"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Lock Count",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "pg_locks_count",
            "legendFormat": "Locks"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Deadlocks",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
        "targets": [
          {
            "expr": "pg_stat_database_deadlocks",
            "legendFormat": "{{datname}}"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Cache Hit Ratio",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read)) * 100",
            "legendFormat": "Cache Hit Ratio"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datname",
          "type": "query",
          "query": "label_values(pg_database_size_bytes, datname)"
        }
      ]
    },
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  },
  "folderId": 0,
  "overwrite": true
}
