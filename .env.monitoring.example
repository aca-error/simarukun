# ==========================================
# MONITORING CONFIGURATION (Tahap 3)
# Copy this file to .env for production
# ==========================================

# SENTRY CONFIGURATION
SENTRY_DSN=your-sentry-dsn-here
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
RELEASE_VERSION=1.2.0
NEXT_PUBLIC_RELEASE_VERSION=1.2.0

# GRAFANA CONFIGURATION
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# PROMETHEUS CONFIGURATION
PROMETHEUS_RETENTION_TIME=30d

# LOKI CONFIGURATION
LOKI_RETENTION_TIME=30d

# ALERTMANAGER CONFIGURATION
ALERTMANAGER_EMAIL_TO=admin@simarukun.com
ALERTMANAGER_EMAIL_FROM=alerts@simarukun.com
ALERTMANAGER_SLACK_WEBHOOK_URL=
ALERTMANAGER_TELEGRAM_BOT_TOKEN=
ALERTMANAGER_TELEGRAM_CHAT_ID=

# MONITORING PORTS
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
POSTGRES_EXPORTER_PORT=9187

# DOCKER NETWORK
MONITORING_NETWORK=simarukun_default
